# ── Frontend (Vercel) environment ───────────────────────────────────────────
#
# Base URL of the backend API (the Hugging Face Space running app/api.py).
# Local dev:   http://localhost:8000
# Production:  https://<your-space-subdomain>.hf.space
#
# The frontend sends its own origin as `return_to` when logging in, so login
# works on every Vercel preview/production domain WITHOUT changing the backend
# — as long as that origin is allowed by the backend's CORS_ALLOW_ORIGINS /
# CORS_ALLOW_ORIGIN_REGEX (the default regex already allows *.vercel.app).
NEXT_PUBLIC_AVATAR_API_BASE=http://localhost:8000

# ── Frontend (Vercel) environment ───────────────────────────────────────────
#
# Base URL of the backend API (the Hugging Face Space running app/api.py).
# If unset, the app defaults to the deployed Space below, so it works on Vercel
# with no configuration. Set this only to point at a different backend.
#   Deployed Space: https://ruslanmv-avatar-renderer.hf.space
#   Local dev:      http://localhost:8000
NEXT_PUBLIC_AVATAR_API_BASE=https://ruslanmv-avatar-renderer.hf.space
